<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:w='urn:import:com.databasepreservation.common.client.widgets'>

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>

    <g:FlowPanel ui:field="content">
        <g:FlowPanel addStyleNames="dialog-customize-columns-options">

            <w:Alert ui:field="fkReferencePanel" />

            <g:FlowPanel ui:field="virtualReferencePanel" addStyleNames="form-helper">

                <w:Alert ui:field="virtualInfoAlert"/>

                <g:FlowPanel addStyleNames="field">
                    <g:HTML addStyleNames="form-label">
                        <ui:text from='{messages.columnManagementLabelForReferencedTable}'/>
                    </g:HTML>
                    <g:ListBox ui:field="referencedTableListBox" addStyleNames="form-textbox"/>
                    <g:Label ui:field="errorReferencedTable" addStyleNames="dialog-input-error-text" visible="false"/>
                </g:FlowPanel>

                <g:FlowPanel addStyleNames="field">
                    <g:HTML addStyleNames="form-label">
                        <ui:text from='{messages.columnManagementLabelForTargetColumn}'/>
                    </g:HTML>
                    <g:ListBox ui:field="referencedColumnListBox" addStyleNames="form-textbox"/>
                    <g:Label ui:field="errorReferencedColumn" addStyleNames="dialog-input-error-text" visible="false"/>

                    <w:Alert ui:field="noCompatibleColumnsMessage" addStyleNames="errormessage" />
                </g:FlowPanel>

                <g:FlowPanel addStyleNames="dialog-tab-footer-actions">
                    <g:Button ui:field="btnRemoveRelationship" addStyleNames="btn btn-outline-danger btn-erase" visible="false">
                        <ui:text from='{messages.basicActionClear}'/>
                    </g:Button>
                </g:FlowPanel>

            </g:FlowPanel>
        </g:FlowPanel>
    </g:FlowPanel>
</ui:UiBinder>
