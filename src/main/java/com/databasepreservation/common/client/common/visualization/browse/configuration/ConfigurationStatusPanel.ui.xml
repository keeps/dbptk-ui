<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:a="urn:import:com.databasepreservation.common.client.widgets">

    <ui:with field='messages' type='config.i18n.client.ClientMessages'/>

    <a:Alert ui:field="alertPanel" addStyleNames="configuration-bar-alert" visible="false">
        <g:FlowPanel addStyleNames="configuration-status-wrapper">

            <g:FlowPanel ui:field="initialStatePanel" addStyleNames="config-state-panel">

                <g:FlowPanel addStyleNames="config-header">
                    <g:Label ui:field="messageLabel" addStyleNames="config-title-text"/>
                    <g:Button ui:field="btnApplyConfiguration" addStyleNames="btn btn-primary btn-play">
                        <ui:text from='{messages.basicActionRun}'/>
                    </g:Button>
                </g:FlowPanel>

                <g:FlowPanel ui:field="pendingStepsContainer" addStyleNames="steps-indicator-container"/>

                <g:FlowPanel addStyleNames="config-footer">
                    <g:FlowPanel addStyleNames="progress-info-panel">
                        <g:Label ui:field="readyToStartLabel" addStyleNames="step-name-progress-label text-muted"/>
                        <g:Label ui:field="elapsedTimePlaceholderLabel" addStyleNames="elapsed-time-label text-muted"/>
                    </g:FlowPanel>
                    <g:HTMLPanel addStyleNames="progress">
                        <g:HTMLPanel addStyleNames="progress-bar inactive-bar"/>
                    </g:HTMLPanel>
                </g:FlowPanel>

            </g:FlowPanel>

            <g:FlowPanel ui:field="progressPanel" visible="false" addStyleNames="config-state-panel">

                <g:FlowPanel addStyleNames="config-header">
                    <g:FlowPanel addStyleNames="job-title-panel">
                        <g:Label ui:field="jobNameLabel" addStyleNames="job-name-label"/>
                        <g:HTML ui:field="statusBadge" addStyleNames="status-badge"/>
                    </g:FlowPanel>
                    <g:Button ui:field="btnGoToJobs" addStyleNames="btn btn-primary btn-jobs">
                        <ui:text from='{messages.configurationStatusPanelLabelForJobsBtn}'/>
                    </g:Button>
                </g:FlowPanel>

                <g:FlowPanel ui:field="stepsContainer" addStyleNames="steps-indicator-container"/>

                <g:FlowPanel addStyleNames="config-footer">
                    <g:FlowPanel addStyleNames="progress-info-panel">
                        <g:Label ui:field="stepNameProgressLabel" addStyleNames="step-name-progress-label"/>
                        <g:Label ui:field="elapsedTimeLabel" addStyleNames="elapsed-time-label"/>
                    </g:FlowPanel>
                    <g:HTMLPanel addStyleNames="progress">
                        <g:HTMLPanel ui:field="progressBar" addStyleNames="progress-bar progress-bar-striped active"/>
                    </g:HTMLPanel>
                </g:FlowPanel>

            </g:FlowPanel>

        </g:FlowPanel>
    </a:Alert>

</ui:UiBinder>
