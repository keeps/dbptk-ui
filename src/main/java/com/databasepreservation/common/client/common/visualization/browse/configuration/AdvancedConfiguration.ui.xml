<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>

    <g:FlowPanel ui:field="mainPanel" addStyleNames="col_12">
        <g:FlowPanel addStyleNames="structure-header" ui:field="header"/>
        <g:SimplePanel ui:field="description" addStyleNames="table-row-description"/>
        <g:FlowPanel addStyleNames="navigation-panels" ui:field="content"/>

        <g:FlowPanel addStyleNames="clearfix"/>

        <g:FlowPanel addStyleNames="navigation-panel-buttons">
            <g:SimplePanel addStyleNames="btn-item">
                <g:Button ui:field="btnReset" addStyleNames="btn btn-danger btn-delete"/>
            </g:SimplePanel>
        </g:FlowPanel>

    </g:FlowPanel>
</ui:UiBinder>
